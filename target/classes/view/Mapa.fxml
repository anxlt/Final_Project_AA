<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="556.0" prefWidth="947.0" style="-fx-background-color: #E3E3E3;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.rutas.visual.controladores.MapaController">

    <Pane fx:id="canvasPane" style="-fx-background-color: #E3E3E3;" AnchorPane.bottomAnchor="70.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <Canvas fx:id="canvas" />
    </Pane>

    <HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="10" style="-fx-background-color: white; -fx-padding: 10 16;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">

        <Region prefHeight="40.0" prefWidth="1.0" style="-fx-background-color: #456882;" />

        <VBox prefHeight="58.0" prefWidth="141.0" spacing="3" HBox.hgrow="NEVER">
            <Label style="-fx-text-fill: #234C6A; -fx-font-size: 9px; -fx-font-weight: bold;" text="ORIGEN" />
            <ComboBox fx:id="cmbOrigen" prefHeight="32.0" prefWidth="150.0" style="-fx-background-color: #1B3C53; -fx-border-color: #456882; -fx-border-radius: 7; -fx-background-radius: 7; -fx-font-size: 12px;" />
        </VBox>

        <VBox spacing="3" HBox.hgrow="NEVER">
            <Label style="-fx-text-fill: #234C6A; -fx-font-size: 9px; -fx-font-weight: bold;" text="DESTINO" />
            <ComboBox fx:id="cmbDestino" prefHeight="32.0" prefWidth="150.0" style="-fx-background-color: #1B3C53; -fx-border-color: #456882; -fx-border-radius: 7; -fx-background-radius: 7; -fx-font-size: 12px;" />
        </VBox>

        <VBox spacing="3" HBox.hgrow="NEVER">
            <Label style="-fx-text-fill: #234C6A; -fx-font-size: 9px; -fx-font-weight: bold;" text="CRITERIO" />
            <ComboBox fx:id="cmbCriterio" prefHeight="32.0" prefWidth="140.0" style="-fx-background-color: #1B3C53; -fx-border-color: #456882; -fx-border-radius: 7; -fx-background-radius: 7; -fx-font-size: 12px;" />
        </VBox>

        <Button fx:id="btnBuscar" mnemonicParsing="false" onAction="#handleBuscar" prefHeight="32.0" prefWidth="80.0" style="-fx-background-color: #1B3C53; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="Buscar" />

        <Region prefHeight="40.0" prefWidth="1.0" style="-fx-background-color: #456882;" />

        <VBox spacing="3" HBox.hgrow="ALWAYS">
            <Label prefHeight="13.0" prefWidth="84.0" style="-fx-text-fill: #234C6A; -fx-font-size: 9px; -fx-font-weight: bold;" text="RUTA ÓPTIMA" />
            <Label fx:id="lblParadas" style="-fx-text-fill: white; -fx-font-size: 11px; -fx-font-weight: bold;" text="" />
        </VBox>

        <HBox alignment="CENTER" spacing="6" HBox.hgrow="NEVER">
            <VBox alignment="CENTER" prefHeight="50.0" prefWidth="53.0" style="-fx-background-color: #1B3C53; -fx-background-radius: 8; -fx-padding: 4 10;">
                <Label prefHeight="13.0" prefWidth="36.0" style="-fx-text-fill: white; -fx-font-size: 9px;" text="TIEMPO" />
                <Label fx:id="lblTiempo" style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;" text="-" />
            </VBox>
            <VBox alignment="CENTER" prefHeight="50.0" prefWidth="53.0" style="-fx-background-color: #1B3C53; -fx-background-radius: 8; -fx-padding: 4 10;">
                <Label prefHeight="13.0" prefWidth="36.0" style="-fx-text-fill: white; -fx-font-size: 9px;" text="COSTO" />
                <Label fx:id="lblCosto" style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;" text="-" />
            </VBox>
            <VBox alignment="CENTER" prefHeight="50.0" prefWidth="67.0" style="-fx-background-color: #1B3C53; -fx-background-radius: 8; -fx-padding: 4 10;">
                <Label prefHeight="13.0" prefWidth="51.0" style="-fx-text-fill: white; -fx-font-size: 9px;" text="DISTANCIA" />
                <Label fx:id="lblDistancia" style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;" text="-" />
            </VBox>
            <VBox alignment="CENTER" style="-fx-background-color: #1B3C53; -fx-background-radius: 8; -fx-padding: 4 10;">
                <Label prefHeight="13.0" prefWidth="68.0" style="-fx-text-fill: white; -fx-font-size: 9px;" text="TRANSBORDOS" />
                <Label fx:id="lblTransbordos" style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;" text="-" />
            </VBox>
        </HBox>

    </HBox>

</AnchorPane>
