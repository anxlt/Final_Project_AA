<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="556.0" prefWidth="947.0" style="-fx-background-color: #E3E3E3;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.rutas.visual.controladores.ParadasController">

    <!-- TOPBAR -->
    <HBox alignment="CENTER_LEFT" prefHeight="72.0" style="-fx-background-color: white; -fx-padding: 16 30 16 30;" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <VBox spacing="3" HBox.hgrow="ALWAYS">
            <Label style="-fx-font-size: 29px; -fx-font-weight: bold; -fx-text-fill: #1B3C53;" text="Paradas" />
            <Label style="-fx-font-size: 13px; -fx-text-fill: #888888;" text="Gestión de paradas del sistema de transporte" />
        </VBox>
        <Button fx:id="btnNuevaParada" mnemonicParsing="false" onAction="#handleNuevaParada" style="-fx-background-color: #1B3C53; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand;" text="+ Nueva Parada" />
    </HBox>


    <HBox alignment="CENTER_LEFT" layoutX="38.0" layoutY="102.0" prefHeight="36.0" spacing="10" AnchorPane.leftAnchor="38.0" AnchorPane.rightAnchor="42.0" AnchorPane.topAnchor="102.0">

        <!-- BUSCADOR -->
        <HBox alignment="CENTER_LEFT" prefHeight="32.0" prefWidth="260.0" spacing="6" style="-fx-background-color: white; -fx-padding: 0 10; -fx-background-radius: 7; -fx-border-color: #DDDDDD; -fx-border-radius: 7;">
            <Label style="-fx-font-size: 13px; -fx-text-fill: #AAAAAA;" text="🔍" />
            <TextField fx:id="txtBuscar" prefHeight="32.0" prefWidth="200.0" promptText="Buscar..." style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-font-size: 12px; -fx-text-fill: #333; -fx-prompt-text-fill: #AAAAAA;" />
        </HBox>

        <!-- FILTRADO TIPO -->
        <ComboBox fx:id="cmbTipo" prefHeight="32.0" prefWidth="170.0" promptText="Todos los tipos" style="-fx-background-color: white; -fx-border-color: #DDDDDD; -fx-border-radius: 7; -fx-background-radius: 7; -fx-font-size: 12px;" />

        <!-- CONTADOR -->
        <Label fx:id="lblContador" prefHeight="32.0" style="-fx-background-color: white; -fx-border-color: #DDDDDD; -fx-border-radius: 7; -fx-background-radius: 7; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #456882; -fx-padding: 6 14;" text="0 paradas" />
    </HBox>

    <!-- TABLA CARD -->
    <VBox layoutY="148.0" prefHeight="396.0" prefWidth="868.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);" AnchorPane.bottomAnchor="12.0" AnchorPane.leftAnchor="39.0" AnchorPane.rightAnchor="40.0" AnchorPane.topAnchor="148.0">

        <TableView fx:id="tablaParadas" style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-table-cell-border-color: #F0F0F0;" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" prefWidth="65.0">
                    <graphic><Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #A0AABB; -fx-padding: 8 0;" text="ID" /></graphic>
                </TableColumn>
                <TableColumn fx:id="colNombre" prefWidth="210.0">
                    <graphic><Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #A0AABB; -fx-padding: 8 0;" text="NOMBRE" /></graphic>
                </TableColumn>
                <TableColumn fx:id="colDireccion" prefWidth="240.0">
                    <graphic><Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #A0AABB; -fx-padding: 8 0;" text="DIRECCIÓN" /></graphic>
                </TableColumn>
                <TableColumn fx:id="colTipo" prefWidth="130.0">
                    <graphic><Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #A0AABB; -fx-padding: 8 0;" text="TIPO" /></graphic>
                </TableColumn>
                <TableColumn fx:id="colAcciones" prefWidth="124.0">
                    <graphic><Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #A0AABB; -fx-padding: 8 0;" text="ACCIONES" /></graphic>
                </TableColumn>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </VBox>

</AnchorPane>
