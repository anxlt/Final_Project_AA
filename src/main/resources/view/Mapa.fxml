<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane fx:id="rootPane" prefHeight="556.0" prefWidth="947.0"
            style="-fx-background-color: #E3E3E3;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.rutas.visual.controladores.MapaController">

    <HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="10"
          style="-fx-background-color: white; -fx-padding: 10 16;"
          AnchorPane.bottomAnchor="0.0"
          AnchorPane.leftAnchor="0.0"
          AnchorPane.rightAnchor="0.0">

        <Region prefHeight="40.0" prefWidth="1.0" style="-fx-background-color: #456882;" />

        <!-- Origen -->
        <VBox spacing="3">
            <Label style="-fx-text-fill: #234C6A; -fx-font-size: 9px; -fx-font-weight: bold;" text="ORIGEN" />
            <Label fx:id="lblOrigen" prefWidth="120.0"
                   style="-fx-text-fill: #00b4d8; -fx-font-size: 12px; -fx-font-weight: bold;" text="Ninguno" />
        </VBox>

        <!-- Destino -->
        <VBox spacing="3">
            <Label style="-fx-text-fill: #234C6A; -fx-font-size: 9px; -fx-font-weight: bold;" text="DESTINO" />
            <Label fx:id="lblDestino" prefWidth="120.0"
                   style="-fx-text-fill: #0077b6; -fx-font-size: 12px; -fx-font-weight: bold;" text="Ninguno" />
        </VBox>

        <!-- Criterio -->
        <VBox spacing="3">
            <Label style="-fx-text-fill: #234C6A; -fx-font-size: 9px; -fx-font-weight: bold;" text="CRITERIO" />
            <ComboBox fx:id="cmbCriterio" prefHeight="32.0" prefWidth="140.0"
                      style="-fx-background-color: #1B3C53; -fx-border-color: #456882;
                             -fx-border-radius: 7; -fx-background-radius: 7; -fx-font-size: 12px;" />
        </VBox>

        <!-- Acciones -->
        <Button text="Buscar" onAction="#handleBuscar" prefHeight="32.0" prefWidth="80.0"
                style="-fx-background-color: #1B3C53; -fx-text-fill: white; -fx-font-size: 12px;
                      -fx-background-radius: 8; -fx-cursor: hand;" />

        <Button text="Limpiar" onAction="#handleLimpiar" prefHeight="32.0" prefWidth="80.0"
                style="-fx-background-color: white; -fx-border-color: #1B3C53;-fx-border-radius: 8;-fx-text-fill: #333; -fx-font-size: 12px;
                      -fx-background-radius: 8; -fx-cursor: hand;" />

        <Region prefHeight="40.0" prefWidth="1.0" style="-fx-background-color: #456882;" />

        <!-- Métricas -->
        <HBox alignment="CENTER" spacing="6" HBox.hgrow="ALWAYS">
            <VBox alignment="CENTER" prefHeight="50.0" prefWidth="64.0"
                  style="-fx-background-color: #1B3C53; -fx-background-radius: 8; -fx-padding: 4 10;">
                <Label style="-fx-text-fill: white; -fx-font-size: 9px;" text="TIEMPO" />
                <Label fx:id="lblTiempo" style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;" text="-" />
            </VBox>
            <VBox alignment="CENTER" prefHeight="50.0" prefWidth="64.0"
                  style="-fx-background-color: #1B3C53; -fx-background-radius: 8; -fx-padding: 4 10;">
                <Label style="-fx-text-fill: white; -fx-font-size: 9px;" text="COSTO" />
                <Label fx:id="lblCosto" style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;" text="-" />
            </VBox>
            <VBox alignment="CENTER" prefHeight="50.0" prefWidth="78.0"
                  style="-fx-background-color: #1B3C53; -fx-background-radius: 8; -fx-padding: 4 10;">
                <Label style="-fx-text-fill: white; -fx-font-size: 9px;" text="DISTANCIA" />
                <Label fx:id="lblDistancia" style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;" text="-" />
            </VBox>
            <VBox alignment="CENTER"
                  style="-fx-background-color: #1B3C53; -fx-background-radius: 8; -fx-padding: 4 10;">
                <Label prefWidth="68.0" style="-fx-text-fill: white; -fx-font-size: 9px;" text="TRANSBORDOS" />
                <Label fx:id="lblTransbordos" style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;" text="-" />
            </VBox>
        </HBox>

    </HBox>

</AnchorPane>
