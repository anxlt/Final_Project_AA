<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.effect.Bloom?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="rootPane" prefHeight="556.0" prefWidth="947.0" style="-fx-background-color: #E3E3E3;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.rutas.visual.controladores.MapaController">

    <HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="0" style="-fx-background-color: white; -fx-padding: 0 16;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
        <Region prefHeight="70.0" prefWidth="0.0" />

        <!-- Origen -->
        <VBox prefHeight="70.0" prefWidth="103.0" spacing="3">
            <Label prefHeight="23.0" prefWidth="79.0" style="-fx-text-fill: #234C6A; -fx-font-size: 11px; -fx-font-weight: bold;" text="ORIGEN">
            <font>
               <Font size="11.0" />
            </font></Label>
            <Label fx:id="lblOrigen" prefWidth="120.0" style="-fx-text-fill: #00b4d8; -fx-font-size: 12px; -fx-font-weight: bold;" text="Ninguno" />
        </VBox>

        <Region prefWidth="16.0" />

        <!-- Destino -->
        <VBox prefHeight="70.0" prefWidth="103.0" spacing="3">
            <Label prefHeight="22.0" prefWidth="83.0" style="-fx-text-fill: #234C6A; -fx-font-size: 11px; -fx-font-weight: bold;" text="DESTINO">
            <font>
               <Font size="11.0" />
            </font></Label>
            <Label fx:id="lblDestino" prefHeight="17.0" prefWidth="111.0" style="-fx-text-fill: #0077b6; -fx-font-size: 12px; -fx-font-weight: bold;" text="Ninguno">
            <font>
               <Font size="14.0" />
            </font></Label>
        </VBox>

        <Region prefHeight="70.0" prefWidth="12.0" />

        <!-- Criterio -->
        <VBox spacing="3">
            <Label prefHeight="19.0" prefWidth="88.0" style="-fx-text-fill: #234C6A; -fx-font-size: 11px; -fx-font-weight: bold;" text="CRITERIO">
            <font>
               <Font size="11.0" />
            </font></Label>
            <ComboBox fx:id="cmbCriterio" prefHeight="32.0" prefWidth="117.0" style="-fx-background-color: #1B3C53;                              -fx-border-color: #456882;                              -fx-border-radius: 7;                              -fx-background-radius: 7;                              -fx-font-size: 12px;                              -fx-focus-color: transparent;                              -fx-faint-focus-color: transparent;" />
        </VBox>

        <Region prefWidth="24.0" />

        <!-- Algoritmo -->
        <VBox spacing="3">
            <Label prefHeight="19.0" prefWidth="99.0" style="-fx-text-fill: #234C6A; -fx-font-size: 11px; -fx-font-weight: bold;" text="ALGORITMO">
            <font>
               <Font size="11.0" />
            </font></Label>
            <ComboBox fx:id="cmbAlgoritmo" prefHeight="32.0" prefWidth="117.0" style="-fx-background-color: #1B3C53;                              -fx-border-color: #456882;                              -fx-border-radius: 7;                              -fx-background-radius: 7;                              -fx-font-size: 12px;                              -fx-focus-color: transparent;                              -fx-faint-focus-color: transparent;" />
        </VBox>

        <Region prefWidth="40.0" />



        <!-- Buscar -->
        <Button onAction="#handleBuscar" prefHeight="32.0" prefWidth="80.0" style="-fx-background-color: #1B3C53; -fx-text-fill: white; -fx-font-size: 12px;                        -fx-background-radius: 8; -fx-cursor: hand;                        -fx-focus-color: transparent; -fx-faint-focus-color: transparent;" text="Buscar" />

        <Region prefWidth="10.0" />

        <!-- Limpiar -->
        <Button onAction="#handleLimpiar" prefHeight="32.0" prefWidth="80.0" style="-fx-background-color: white; -fx-border-color: #1B3C53; -fx-border-radius: 8;                        -fx-text-fill: #333; -fx-font-size: 12px;                        -fx-background-radius: 8; -fx-cursor: hand;                        -fx-focus-color: transparent; -fx-faint-focus-color: transparent;" text="Limpiar" />

        <Region prefWidth="10.0" />

        <!-- Alternativo -->
        <Button fx:id="btnAlternativo" onAction="#handleBuscarAlternativo" prefHeight="32.0" prefWidth="85.0" style="-fx-background-color: #1B3C53; -fx-text-fill: white; -fx-font-size: 11px;                        -fx-background-radius: 8; -fx-cursor: hand;                        -fx-focus-color: transparent; -fx-faint-focus-color: transparent;" text="Alternativo" />

        <Region prefHeight="70.0" prefWidth="24.0" />

        <!-- Total -->
        <VBox prefHeight="70.0" prefWidth="103.0" spacing="3">
            <Label prefHeight="25.0" prefWidth="106.0" style="-fx-text-fill: #234C6A; -fx-font-size: 11px; -fx-font-weight: bold;" text="TOTAL">
            <font>
               <Font size="11.0" />
            </font></Label>
            <HBox alignment="CENTER_LEFT" prefHeight="17.0" prefWidth="77.0" spacing="4">
                <Label fx:id="lblTotal" prefHeight="17.0" prefWidth="31.0" style="-fx-text-fill: #F0A500; -fx-font-size: 12px; -fx-font-weight: bold;" text="—" />
                <Label fx:id="lblUnidad" alignment="CENTER" prefHeight="16.0" prefWidth="19.0" style="-fx-text-fill: #888; -fx-font-size: 11px;" text="" />
            </HBox>
         <effect>
            <Bloom />
         </effect>
        </VBox>
    </HBox>

</AnchorPane>
