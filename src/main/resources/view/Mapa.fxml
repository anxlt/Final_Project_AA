<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane fx:id="rootPane" prefHeight="556.0" prefWidth="947.0"
            style="-fx-background-color: #E3E3E3;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.rutas.visual.controladores.MapaController">

    <HBox alignment="CENTER_LEFT" prefHeight="52.0" spacing="0"
          style="-fx-background-color: white; -fx-padding: 0 16;"
          AnchorPane.bottomAnchor="0.0"
          AnchorPane.leftAnchor="0.0"
          AnchorPane.rightAnchor="0.0">

        <Region prefHeight="40.0" prefWidth="1.0" style="-fx-background-color: #456882;" />
        <Region prefWidth="10.0" />

        <!-- Origen -->
        <VBox spacing="3">
            <Label style="-fx-text-fill: #234C6A; -fx-font-size: 9px; -fx-font-weight: bold;" text="ORIGEN" />
            <Label fx:id="lblOrigen" prefWidth="120.0"
                   style="-fx-text-fill: #00b4d8; -fx-font-size: 12px; -fx-font-weight: bold;" text="Ninguno" />
        </VBox>

        <Region prefWidth="16.0" />

        <!-- Destino -->
        <VBox spacing="3">
            <Label style="-fx-text-fill: #234C6A; -fx-font-size: 9px; -fx-font-weight: bold;" text="DESTINO" />
            <Label fx:id="lblDestino" prefWidth="120.0"
                   style="-fx-text-fill: #0077b6; -fx-font-size: 12px; -fx-font-weight: bold;" text="Ninguno" />
        </VBox>

        <Region prefWidth="24.0" />

        <!-- Criterio -->
        <VBox spacing="3">
            <Label style="-fx-text-fill: #234C6A; -fx-font-size: 9px; -fx-font-weight: bold;" text="CRITERIO" />
            <ComboBox fx:id="cmbCriterio" prefHeight="32.0" prefWidth="140.0"
                      style="-fx-background-color: #1B3C53;
                             -fx-border-color: #456882;
                             -fx-border-radius: 7;
                             -fx-background-radius: 7;
                             -fx-font-size: 12px;
                             -fx-focus-color: transparent;
                             -fx-faint-focus-color: transparent;" />
        </VBox>

        <Region prefWidth="24.0" />

        <!-- Algoritmo -->
        <VBox spacing="3">
            <Label style="-fx-text-fill: #234C6A; -fx-font-size: 9px; -fx-font-weight: bold;" text="ALGORITMO" />
            <ComboBox fx:id="cmbAlgoritmo" prefHeight="32.0" prefWidth="150.0"
                      style="-fx-background-color: #1B3C53;
                             -fx-border-color: #456882;
                             -fx-border-radius: 7;
                             -fx-background-radius: 7;
                             -fx-font-size: 12px;
                             -fx-focus-color: transparent;
                             -fx-faint-focus-color: transparent;" />
        </VBox>

        <!-- Espaciado generoso antes de botones -->
        <Region prefWidth="40.0" />

        <!-- Buscar -->
        <Button text="Buscar" onAction="#handleBuscar" prefHeight="32.0" prefWidth="80.0"
                style="-fx-background-color: #1B3C53; -fx-text-fill: white; -fx-font-size: 12px;
                       -fx-background-radius: 8; -fx-cursor: hand;
                       -fx-focus-color: transparent; -fx-faint-focus-color: transparent;" />

        <Region prefWidth="10.0" />

        <!-- Limpiar -->
        <Button text="Limpiar" onAction="#handleLimpiar" prefHeight="32.0" prefWidth="80.0"
                style="-fx-background-color: white; -fx-border-color: #1B3C53; -fx-border-radius: 8;
                       -fx-text-fill: #333; -fx-font-size: 12px;
                       -fx-background-radius: 8; -fx-cursor: hand;
                       -fx-focus-color: transparent; -fx-faint-focus-color: transparent;" />

        <Region prefWidth="10.0" />

        <!-- Alternativo -->
        <Button fx:id="btnAlternativo" text="Alternativo" onAction="#handleBuscarAlternativo"
                prefHeight="32.0" prefWidth="85.0"
                style="-fx-background-color: #1B3C53; -fx-text-fill: white; -fx-font-size: 11px;
                       -fx-background-radius: 8; -fx-cursor: hand;
                       -fx-focus-color: transparent; -fx-faint-focus-color: transparent;" />

        <Region prefWidth="10.0" />
        <Region prefHeight="40.0" prefWidth="1.0" style="-fx-background-color: #456882;" />

    </HBox>

</AnchorPane>
