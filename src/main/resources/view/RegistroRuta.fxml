<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="560.0" prefWidth="488.0"
            style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 10;"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.rutas.visual.controladores.RegistroRutaController">

    <Label fx:id="lblTitulo" layoutX="32.0" layoutY="32.0"
           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1B3C53;" text="Nueva Ruta" />

    <!-- NOMBRE -->
    <Label layoutX="32.0" layoutY="90.0"
           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1B3C53;" text="Nombre de la ruta" />
    <TextField fx:id="txtNombre" layoutX="32.0" layoutY="112.0" prefHeight="42.0" prefWidth="416.0"
               promptText="Ej: Ruta Norte-Sur"
               style="-fx-background-color: white; -fx-border-color: #DDDDDD; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 13px; -fx-padding: 0 12;" />

    <!-- ORIGEN -->
    <Label layoutX="32.0" layoutY="168.0"
           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1B3C53;" text="Parada origen" />
    <ComboBox fx:id="cmbOrigen" layoutX="32.0" layoutY="190.0" prefHeight="42.0" prefWidth="416.0"
              promptText="Seleccionar..."
              style="-fx-background-color: white; -fx-border-color: #DDDDDD; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 13px;" />

    <!-- DESTINO -->
    <Label layoutX="32.0" layoutY="246.0"
           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1B3C53;" text="Parada destino" />
    <ComboBox fx:id="cmbDestino" layoutX="32.0" layoutY="268.0" prefHeight="42.0" prefWidth="416.0"
              promptText="Seleccionar..."
              style="-fx-background-color: white; -fx-border-color: #DDDDDD; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 13px;" />

    <!-- PESOS -->
    <HBox layoutX="32.0" layoutY="324.0" prefWidth="416.0" spacing="12">

        <VBox spacing="4">
            <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #1B3C53;" text="Tiempo (min)" />
            <Spinner fx:id="spnTiempo" prefHeight="42.0" prefWidth="95.0"
                     style="-fx-background-color: white; -fx-border-color: #DDDDDD; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 13px;" />
        </VBox>

        <VBox spacing="4">
            <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #1B3C53;" text="Costo (RD$)" />
            <Spinner fx:id="spnCosto" prefHeight="42.0" prefWidth="95.0"
                     style="-fx-background-color: white; -fx-border-color: #DDDDDD; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 13px;" />
        </VBox>

        <VBox spacing="4">
            <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #1B3C53;" text="Distancia (km)" />
            <Spinner fx:id="spnDistancia" prefHeight="42.0" prefWidth="95.0"
                     style="-fx-background-color: white; -fx-border-color: #DDDDDD; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 13px;" />
        </VBox>

        <VBox spacing="4">
            <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #1B3C53;" text="Transbordos" />
            <Spinner fx:id="spnTransbordos" prefHeight="42.0" prefWidth="95.0"
                     style="-fx-background-color: white; -fx-border-color: #DDDDDD; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 13px;" />
        </VBox>

    </HBox>

    <!-- BOTONES -->
    <HBox alignment="CENTER_RIGHT" layoutX="116.0" layoutY="470.0" prefHeight="42.0" prefWidth="332.0" spacing="12">
        <Button mnemonicParsing="false" onAction="#handleCancelar" prefHeight="42.0" prefWidth="120.0"
                style="-fx-background-color: white; -fx-border-color: #DDDDDD; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 13px; -fx-cursor: hand; -fx-text-fill: #333;"
                text="Cancelar" />
        <Button mnemonicParsing="false" onAction="#handleGuardar" prefHeight="42.0" prefWidth="120.0"
                style="-fx-background-color: #1B3C53; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"
                text="Guardar" />
    </HBox>

</AnchorPane>